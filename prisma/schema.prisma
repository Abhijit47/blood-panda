// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MODERATOR
  USER
}

model User {
  id            String    @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String    @default("https://avatar.vercel.sh/rauchg?rounded=60")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          Role      @default(USER)
  sessions      Session[]
  accounts      Account[]

  posts    Post[]
  bookings Booking[]
  payments Payment[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  accountId             String
  providerId            String
  userId                String    @db.Uuid
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Post {
  id         String   @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  title      String
  slug       String   @unique
  postCover  String
  summary    String
  content    String   @db.Text // 👈 Add this
  categories String[]
  authorId   String   @db.Uuid
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  draft      Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([authorId, slug])
  @@map("post")
}

model PrimaryCategory {
  id   String @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  name String

  tests     BloodTest[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("primary_category")
}

model SecondaryCategory {
  id   String @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  name String @default("General")

  tests BloodTest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("secondary_category")
}

model BloodTest {
  id              String @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid
  name            String @unique
  originalPrice   String
  discountedPrice String
  discountAmount  String @default("30")

  isFastingRequired Boolean @default(false)

  primaryCategoryId   String            @db.Uuid
  primaryCategory     PrimaryCategory   @relation(fields: [primaryCategoryId], references: [id], onDelete: Cascade)
  secondaryCategoryId String            @db.Uuid
  secondaryCategory   SecondaryCategory @relation(fields: [secondaryCategoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  member   Member? @relation(fields: [memberId], references: [id])
  memberId String? @db.Uuid

  @@index([name])
  @@map("blood_test")
}

model PackageCategory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique
  features  String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  packages Package[] @relation("PackageToPackageCategory")

  @@map("package_category")
}

model Package {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  name             String   @unique
  description      String
  cover            String   @default("/packages-bg.png")
  originalAmount   String
  discountedAmount String
  offerAmount      String   @default("30")
  extraFeatures    String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  packageCategories PackageCategory[] @relation("PackageToPackageCategory")

  @@index([name])
  @@map("package")
}

model MiniPackage {
  id String @id @default(dbgenerated("pg_catalog.gen_random_uuid()")) @db.Uuid

  name             String   @unique
  description      String
  cover            String   @default("/packages-bg.png")
  benefits         String[]
  originalAmount   String
  discountedAmount String
  offerAmount      String   @default("30")
  extraFeatures    String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([id, name])
  @@index([name])
  @@map("mini_package")
}

//*******************************************************

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Member {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  name   String
  email  String
  phone  String
  gender Gender
  age    String

  testItems BloodTest[]

  booking   Booking? @relation(fields: [bookingId], references: [id])
  bookingId String?  @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@map("member")
}

enum AddressType {
  HOME
  OTHER
}

model Address {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  type     AddressType @default(HOME)
  location String
  houseNo  String
  landmark String?
  pinCode  String

  streetAddress String?
  city          String?
  state         String?
  country       String?

  booking   Booking? @relation(fields: [bookingId], references: [id])
  bookingId String?  @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, pinCode])
  @@map("address")
}

model Schedule {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  scheduleDate DateTime
  slot         String

  booking   Booking? @relation(fields: [bookingId], references: [id])
  bookingId String?  @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scheduleDate, slot])
  @@map("schedule")
}

enum BookingStatus {
  PENDING // Booking is created but payment is not done yet. This will help in tracking the bookings that are pending and those that are paid.
  CONFIRMED // Booking is confirmed after payment is done. This will help in tracking the bookings that are confirmed and those that are still pending.
  CANCELLED // Booking is cancelled based on payment failure or user cancellation. This will help in tracking the bookings that are cancelled and those that are still pending.
  COMPLETED // Admin can mark the booking as completed after the test is done and report is generated. This will help in tracking the bookings that are completed and those that are still pending.
}

enum BookingType {
  COD
  ONLINE_PAYMENT
}

model Booking {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  type   BookingType   @default(COD)
  status BookingStatus @default(PENDING)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   Member[]
  addresses Address[]
  schedules Schedule[]
  payments  Payment[]

  // @@index([id, userId, addressId, scheduleId])
  @@map("booking")
}

model Payment {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  merchantId      String
  merchantOrderId String
  orderId         String
  state           String
  amount          String
  currency        String
  expireAt        String

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bookingId String  @db.Uuid
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  webhookLogs WebhookLog[]

  @@index([userId, bookingId, merchantOrderId, orderId, state])
  @@map("payment")
}

model WebhookLog {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  payload Json @db.JsonB

  paymentId String  @db.Uuid
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([paymentId])
  @@map("webhook_log")
}
